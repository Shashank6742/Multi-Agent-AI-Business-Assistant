# Free Groq cloud API — get a key at https://console.groq.com/keys (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Where the RAG vector database is stored locally
CHROMA_DB_PATH=data/chroma_db

# Where source documents for RAG live (pdf, docx, txt)
DOCUMENTS_PATH=data/documents
